---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { CATEGORIES } from '../../../consts';
import type { CategorySlug } from '../../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);

  return Object.keys(CATEGORIES).map((slug) => {
    const category = slug as CategorySlug;
    const inCat = posts
      .filter((p) => p.data.category === category)
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
    return { params: { category }, props: { category, posts: inCat } };
  });
}

const { category, posts } = Astro.props as {
  category: CategorySlug;
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
};
const cat = CATEGORIES[category];
---
<BaseLayout
  title={`${cat.label} | Blog — FS Psicologia Clínica`}
  description={cat.description}
  path={`/blog/categoria/${category}`}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/blog.css" />
  </Fragment>

  <main class="blog-main">
    <section class="blog-hero">
      <div class="container">
        <p class="post-cat-link" style="display:block;margin-bottom:6px;">Categoria</p>
        <h1 class="blog-title">{cat.label}</h1>
        <p class="blog-intro">{cat.description}</p>
        <nav class="cluster-nav" aria-label="Categorias do blog">
          {Object.entries(CATEGORIES).map(([slug, c]) => (
            <a
              class="cluster-chip"
              href={`/blog/categoria/${slug}`}
              aria-current={slug === category ? 'page' : undefined}
            >{c.label}</a>
          ))}
        </nav>
      </div>
    </section>

    <section class="post-list">
      <div class="container">
        {posts.length === 0 ? (
          <p class="empty-note">Ainda não há textos nesta categoria. <a href="/blog">Ver todos os posts →</a></p>
        ) : (
          <div class="post-grid">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
