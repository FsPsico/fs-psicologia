---
// Shared <head>: SEO meta, OG/Twitter, fonts, favicons, global stylesheet.
// Reproduces the original landing <head> and parametrizes it per page.
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  /** Path or absolute URL for the page (canonical/OG). Defaults to current. */
  path?: string;
  /** OG image: absolute URL or site-relative path. */
  image?: string;
  imageAlt?: string;
  /** 'website' for landing/index pages, 'article' for blog posts. */
  ogType?: 'website' | 'article';
  /** Article metadata (only for blog posts). */
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = SITE.defaultDescription,
  path = Astro.url.pathname,
  image = SITE.defaultOgImage,
  imageAlt = 'FS Psicologia Clínica e Saúde Mental — Felipe Zecchin Salim, CRP 06/216021',
  ogType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonical = new URL(path, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;
---
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- Primary SEO -->
<title>{title}</title>
<meta name="description" content={description}>
<meta name="author" content="Felipe Zecchin Salim">
<meta name="robots" content="index, follow">
<link rel="canonical" href={canonical}>
<meta name="theme-color" content={SITE.themeColor}>

<!-- Open Graph -->
<meta property="og:type" content={ogType}>
<meta property="og:locale" content="pt_BR">
<meta property="og:site_name" content="FS Psicologia Clínica e Saúde Mental">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content={imageAlt}>
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>

<!-- Icons -->
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16.png">
<link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png">

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="Blog — FS Psicologia Clínica" href={new URL('/rss.xml', SITE.url).href}>

<!-- Fonts: preconnect + async (non-render-blocking), font-display: swap -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&display=swap" media="print" onload="this.media='all'">
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&display=swap">
</noscript>

<link rel="stylesheet" href="/assets/css/styles.css">
<script is:inline>
  /* Enable reveal animations only when JS is present; guarantee content
     becomes visible after 2s even if main.js fails to load. */
  document.documentElement.classList.add('js');
  setTimeout(function () { document.documentElement.classList.add('reveal-fallback'); }, 2000);
</script>
