---
// Shared site header — same nav on every page (landing and blog), so the
// header is consistent and the blog is reachable from the home.
// `p` makes the in-page anchors work from both contexts: same-page on the
// landing, and /#… (back to the landing) on blog pages.
import { WHATSAPP } from '../consts';
interface Props { home?: boolean }
const { home = false } = Astro.props;
const p = home ? '' : '/';
---
<header class="site-header">
  <div class="nav-inner">
    <a href={home ? '#inicio' : '/'} class="brand" aria-label="FS Psicologia Clínica — início">
      <picture>
        <source type="image/webp" srcset="/assets/img/logo.webp">
        <img src="/assets/img/logo.png" alt="" width="40" height="40" class="brand-mark">
      </picture>
      <span class="brand-name">FS Psicologia Clínica</span>
    </a>

    <nav class="nav-desktop" aria-label="Navegação principal">
      <a href={p + '#sobre'} class="nav-link">Sobre</a>
      <a href={p + '#metodo'} class="nav-link">Como trabalho</a>
      <a href={p + '#para-quem'} class="nav-link">Para quem</a>
      <a href={p + '#atendimento'} class="nav-link">Atendimento</a>
      <a href={p + '#faq'} class="nav-link">Perguntas</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href={WHATSAPP} target="_blank" rel="noopener" class="nav-cta">WhatsApp</a>
    </nav>

    <button class="nav-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="mobile-menu" hidden>
    <a href={p + '#sobre'}>Sobre</a>
    <a href={p + '#metodo'}>Como trabalho</a>
    <a href={p + '#para-quem'}>Para quem</a>
    <a href={p + '#atendimento'}>Atendimento</a>
    <a href={p + '#faq'}>Perguntas frequentes</a>
    <a href="/blog">Blog</a>
    <a href={WHATSAPP} target="_blank" rel="noopener" class="nav-cta-mobile">Conversar pelo WhatsApp</a>
  </div>
</header>
