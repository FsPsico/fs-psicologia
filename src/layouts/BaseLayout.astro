---
// Page shell shared by the landing and the blog. Each page supplies its own
// <main> in the default slot; extra <head> tags (e.g. JSON-LD) go in the
// named "head" slot.
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  path?: string;
  image?: string;
  imageAlt?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  /** Landing renders in-page anchors; blog pages link back to the landing. */
  home?: boolean;
}

const { home = false, ...head } = Astro.props;
---
<!DOCTYPE html>
<html lang={SITE.lang}>
<head>
  <BaseHead {...head} />
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#inicio">Pular para o conteúdo</a>
  <Header home={home} />
  <slot />
  <Footer />
  <script src="/assets/js/main.js" defer></script>
</body>
</html>
